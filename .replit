modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TV Show Cleanup"

[[workflows.workflow]]
name = "TV Show Cleanup"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python cleanup.py"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "scheduled"
run = ["python", "cleanup.py", "--auto", "--execute"]
